rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ユーザーは自分の暗号化キーのみアクセス可能
    match /userEncryptionKeys/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // スケジューラ: 空き時間
    match /availability/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && docId.matches(request.auth.uid + '_.*');
    }

    // スケジューラ: 定期スケジュール
    match /recurringSchedule/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && docId.matches(request.auth.uid + '_.*');
    }

    // ユーザープロフィール
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;

      // アセットライブラリ
      match /assets/{assetId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Adrastea: TRPG盤面共有（オーナー限定）
    function isRoomOwner(roomId) {
      return request.auth != null
        && get(/databases/$(database)/documents/rooms/$(roomId)).data.owner_uid == request.auth.uid;
    }

    match /rooms/{roomId} {
      // 読み取り: 認証済みなら誰でも（ゲスト含む）
      allow get, list: if request.auth != null;
      // 更新・削除: オーナーのみ
      allow update, delete: if request.auth != null
        && resource.data.owner_uid == request.auth.uid;
      // 作成: 認証済み + owner_uid が自分
      allow create: if request.auth != null
        && request.resource.data.owner_uid == request.auth.uid;

      // サブコレクション: read は認証済みユーザー、write はオーナーのみ
      match /pieces/{pieceId} {
        allow read: if request.auth != null;
        allow write: if isRoomOwner(roomId);
      }
      match /messages/{messageId} {
        allow read: if request.auth != null;
        allow write: if isRoomOwner(roomId);
      }
      match /scenes/{sceneId} {
        allow read: if request.auth != null;
        allow write: if isRoomOwner(roomId);
        match /objects/{objectId} {
          allow read: if request.auth != null;
          allow write: if isRoomOwner(roomId);
        }
      }
      match /bgms/{bgmId} {
        allow read: if request.auth != null;
        allow write: if isRoomOwner(roomId);
      }
      match /objects/{objectId} {
        allow read: if request.auth != null;
        allow write: if isRoomOwner(roomId);
      }
      match /characters/{characterId} {
        allow read: if request.auth != null;
        allow write: if isRoomOwner(roomId);
      }
      match /scenario_texts/{textId} {
        allow read: if request.auth != null;
        allow write: if isRoomOwner(roomId);
      }
      match /cutins/{cutinId} {
        allow read: if request.auth != null;
        allow write: if isRoomOwner(roomId);
      }
    }
  }
}
